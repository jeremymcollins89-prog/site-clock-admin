{
  "name": "coll-timeclock-admin",
  "version": "2.7.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "dist:store": "electron-builder --win appx",
    "release": "electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.collbusinesssolutions.admin",
    "productName": "Coll Timeclock Admin",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Coll-Timeclock-Admin-Setup.exe"
    },
    "appx": {
      "identityName": "jcollins.CollTimeclock",
      "publisher": "CN=55D9F888-409D-4342-BEA9-1BAFF153D7C5",
      "publisherDisplayName": "jcollins",
      "applicationId": "CollTimeclockAdmin",
      "displayName": "Coll Timeclock",
      "backgroundColor": "#C1502E"
    },
    "publish": {
      "provider": "github",
      "owner": "jeremymcollins89-prog",
      "repo": "site-clock-admin"
    }
  }
}